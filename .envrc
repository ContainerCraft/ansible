# =============================================================================
# direnv environment configuration — ContainerCraft/ansible
# =============================================================================
#
# Activates this repository's OWN flake devshell (.#default), which inherits the
# konductor `full` toolchain (ansible-core + httpx, wrapped yamllint/ansible-lint)
# and layers the vendored oxlorg.opnsense collection on top (see ./flake.nix).
# This is distinct from the konductor monorepo anchor: this repo carries no
# cluster/Pulumi/PKI machinery — only the Ansible automation and its secrets.
#
# Setup:
#   1. Install direnv + nix-direnv (https://github.com/nix-community/nix-direnv)
#   2. eval "$(direnv hook bash)"  # or zsh
#   3. cd into this directory; run: direnv allow
#
# Overrides:
#   DEVSHELL_FLAKE: override the flake source (local path or URI)
#   DEVSHELL_NAME:  override the devshell output name (default: default)

export WORKSPACE_ROOT="${WORKSPACE_ROOT:-$PWD}"
export DIRENV_LOG_FORMAT=""
export KONDUCTOR_SKIP_BANNER=1
export KONDUCTOR_QUIET=1

# =============================================================================
# Environment files — repo-root toolchain only
# =============================================================================
# This root .envrc loads .env directly (single layer). Per-deploy .envrc files
# (e.g. deploy/opnsense/.envrc) use a three-tier model:
#   .env.example (committed defaults) < sesame vault < .env (overrides)
# The two are independent — cd into the deploy dir to get its precedence.
dotenv_if_exists /etc/konductor/proxy.env
dotenv_if_exists .env.http_proxy
dotenv_if_exists .env

# =============================================================================
# Sesame Vault Secrets
# =============================================================================
# OPNsense API credentials and CARP/hasync passwords are consumed by the
# automation from the environment (OPNSENSE_API_KEY/SECRET, OPNSENSE_CARP_PASSWORD,
# OPNSENSE_HASYNC_PASSWORD). Source them from the sesame vault when available.
export SESAME_PROFILES="${SESAME_PROFILES:-default}"
if command -v sesame &>/dev/null; then
  eval "$(sesame export 2>/dev/null)" || true
fi

# =============================================================================
# Nix Devshell Activation — this repo's own flake (.#default)
# =============================================================================
# Activate this repo's flake devshell UNLESS the toolchain is already pre-loaded.
# Pre-loaded means: inside the Konductor VM (/.konductor marker file), or already
# inside any nix devshell (IN_NIX_SHELL). The inherited KONDUCTOR env var is NOT
# used as a skip signal — it leaks from parent shells on a host and would wrongly
# skip activation, leaving ansible off PATH. _DIRENV_CHILD_SOURCING avoids
# re-entry when a parent .envrc sources this one.
if [[ -f /.konductor ]] || [[ -n "${IN_NIX_SHELL:-}" ]]; then
  # Toolchain already present; export metadata only, do not re-evaluate.
  export DEVSHELL_NAME="${DEVSHELL_NAME:-konductor}"
  export DEVSHELL_FLAKE="${DEVSHELL_FLAKE:-builtin}"
elif [[ -z "${_DIRENV_CHILD_SOURCING:-}" ]]; then
  DEVSHELL_NAME="${DEVSHELL_NAME:-default}"
  export DEVSHELL_NAME

  # Prefer frolic: it materializes the built devshell to .direnv/frolic-<name>.sh
  # and sources the cache on subsequent loads, making switches instant instead of
  # re-evaluating the full konductor closure every time. use_frolic targets this
  # repo's own flake (.#<name>) and falls back to `use flake` if frolic is absent
  # or its build fails. An explicit DEVSHELL_FLAKE override forces plain use flake.
  if [[ -z "${DEVSHELL_FLAKE:-}" ]] && declare -f use_frolic >/dev/null 2>&1; then
    use_frolic "${DEVSHELL_NAME}"
  else
    DEVSHELL_FLAKE="${DEVSHELL_FLAKE:-path:${WORKSPACE_ROOT}}"
    export DEVSHELL_FLAKE
    watch_file flake.nix
    watch_file flake.lock
    use flake "${DEVSHELL_FLAKE}#${DEVSHELL_NAME}"
  fi
fi

# Ensure WORKSPACE_ROOT persists after flake activation.
export WORKSPACE_ROOT="${WORKSPACE_ROOT:-$PWD}"

# =============================================================================
# Monorepo dev shell only — no per-collection operator config here.
# =============================================================================
# This root .envrc activates the konductor toolchain for developing and
# maintaining the whole monorepo. Per-collection operator configuration (env
# precedence, ANSIBLE_CONFIG, OPNSENSE_* defaults, collection install) lives in
# each deploy tree's own .envrc, e.g. deploy/opnsense/.envrc.
