# =============================================================================
# direnv environment — ContainerCraft OPNsense deploy
# =============================================================================
#
# Operator entrypoint for running the OPNsense automation against the live box.
#
# Configuration precedence (lowest -> highest, later wins):
#   1. .env.example  — committed, REAL operationalized defaults (live lab box).
#                      This is sourced, not a template. A bare checkout runs as-is.
#   2. sesame vault  — secrets (API key/secret, CARP/hasync passwords).
#   3. .env          — gitignored. Users write ONLY the values they want to
#                      override from .env.example; everything else is inherited.
#
# The ansible toolchain (ansible-core + ansible-galaxy) ships via the konductor
# flake; it is always present, never guarded.
#
# Setup:
#   direnv allow                    # runs as-is with .env.example defaults
#   # optional: echo 'OPNSENSE_NETWORK_PHASE=migrating' > .env   # override one value

export DIRENV_LOG_FORMAT=""

# =============================================================================
# Environment files (precedence: .env.example < sesame < .env)
# =============================================================================
dotenv_if_exists /etc/konductor/proxy.env
dotenv_if_exists .env.http_proxy

# 1. Committed real defaults — the operationalized baseline.
dotenv_if_exists .env.example

# 2. Sesame vault secrets. OPNSENSE_API_KEY/SECRET, OPNSENSE_CARP_PASSWORD,
#    OPNSENSE_HASYNC_PASSWORD come from the vault; it runs after .env.example so
#    real secrets replace the blank defaults.
export SESAME_PROFILES="${SESAME_PROFILES:-default}"
if command -v sesame &>/dev/null; then
  eval "$(sesame export 2>/dev/null)" || true
fi

# 3. User overrides — highest precedence. Only what the operator wants to differ
#    from .env.example / sesame. Gitignored.
dotenv_if_exists .env

# =============================================================================
# Ansible configuration
# =============================================================================
export ANSIBLE_CONFIG="${ANSIBLE_CONFIG:-${PWD}/ansible.cfg}"

# =============================================================================
# Collections — install into the playbook-adjacent collections/ directory
# =============================================================================
# The adjacent collections/ dir takes precedence over ANSIBLE_COLLECTIONS_PATH
# (the konductor devshell sets that to the nix-store vendored oxlorg path).
# Re-install when requirements.yml changes (tracked via a stamp file, not the
# collections/ directory mtime which changes on .pyc writes at runtime).
watch_file requirements.yml
_collections_stamp=".direnv/collections.stamp"
if [[ ! -d collections/ansible_collections/containercraft/opnsense ]] \
   || [[ ! -f "$_collections_stamp" ]] \
   || [[ requirements.yml -nt "$_collections_stamp" ]]; then
  ansible-galaxy collection install -r requirements.yml -p collections --force \
    && mkdir -p .direnv && touch "$_collections_stamp" \
    && log_status "collections installed (containercraft.opnsense, oxlorg.opnsense)"
fi
